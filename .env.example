# Conexión a la base de datos MySQL de Hostinger (o local para desarrollo).
# Formato: mysql://usuario:password@host:puerto/nombre_base
DATABASE_URL="mysql://usuario:password@localhost:3306/sgd_suoc"

# Zona horaria de la aplicación (se usa para mostrar fechas en hora paraguaya).
TZ="America/Asuncion"

# Clave secreta para firmar la cookie de sesión. Generarla con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Si se cambia, se cierran todas las sesiones activas.
SESSION_SECRET="reemplazar_por_una_clave_generada"
